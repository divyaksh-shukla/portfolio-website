<style lang="scss">
    $w-s: 750px;
    $w-s-roles: 850px;

    .divyaksh-title-container {
        display: flex;
        min-height: calc(100vh - 58px);
        font-family: "Open Sans", sans-serif;
        .divyaksh-title {
            align-self: center;
            display: grid;
            align-items: start;
            column-gap: 4em;
            grid-template-areas:
                "pic title title title title"
                // "pic info info info info"
                "pic education education education education"
                "pic roles roles roles roles"
                "pic desc desc desc desc"
                "pic desc desc desc desc"
                "pic desc desc desc desc"
                "pic desc desc desc desc"
                "pic desc desc desc desc"
                "pic desc desc desc desc"
                "bio desc desc desc desc";
            @media (max-width: $w-s) {
                grid-template-areas:
                    "title pic pic"
                    "info info info"
                    "education education education"
                    "roles roles roles"
                    "desc desc desc"
                    "bio bio bio";
            }
            .title {
                margin: 0px;
                grid-area: title;
                font-family: "Open Sans", sans-serif;
                font-weight: 450;
                display: grid;
                font-size: var(--f-u9);
                @media (max-width: $w-s) {
                    font-size: var(--f-u7);
                }
                .subtitle {
                    font-weight: 400;
                    font-size: var(--f-d5);
                    letter-spacing: 2px;
                    align-self: end;
                }
            }
            .mobile {
                display: none;
                @media (max-width: $w-s-roles) {
                    display: block;
                }
            }
            .desktop {
                display: block;
                @media (max-width: $w-s-roles) {
                    display: none;
                }
            }
            .roles {
                grid-area: roles;
                margin: 1em 0;
                font-weight: 600;
                .role {
                    background-color: var(--c-grey);
                    color: var(--t-bg);
                    padding: 0.4em 0.8em;

                    cursor: default;
                    transition: color linear 150ms;
                    &:hover {
                        color: var(--t-active);
                    }
                }
                @media (max-width: $w-s-roles) {
                    font-size: var(--f-d1);
                }
                .last {
                    border-radius: 0px 20px 20px 0px;
                    @media (max-width: $w-s-roles) {
                        border-radius: 0px 0px 10px 10px;
                    }
                }
                .first {
                    border-radius: 20px 0px 0px 20px;
                    @media (max-width: $w-s-roles) {
                        border-radius: 10px 10px 0px 0px;
                    }
                }
            }
            .education-list {
                grid-area: education;
                font-weight: lighter;
                font-size: var(--f-u3);
                background-color: wheat;
                padding: 4px 12px;
                border-radius: 5px;
                @media (max-width: $w-s) {
                    font-size: var(--f-d2);
                    font-weight: normal;
                }
            }
            .description {
                grid-area: desc;
                text-align: justify;
                text-justify: auto;
                font-size: var(--f-u2);
                @media (max-width: $w-s) {
                    font-size: var(--f-d1);
                }
            }
            .profile-pic {
                grid-area: pic;
                img {
                    max-height: 350px;
                    border-radius: 50%;
                }
            }
            .personal-info {
                grid-area: info;
                display: none;
                column-gap: 2ch;
                grid-auto-flow: column;
                width: max-content;
                @media screen and (max-width: $w-s) {
                    display: none;
                    grid-auto-flow: row;
                }
            }
            .sectionTitle {
                margin: 0px
            }
            .bio {
                line-height: 1.5;
                margin-bottom: 2rem;

                > span:first-of-type {
                    line-height: 1;
                    margin-bottom: 0.5em;
                    display: block;
                    // font-weight: 700;
                    font-size: var(--f-u4);
                }
            }
            .side-bio {
                display: flex;
                flex-direction: column;
                grid-area: bio;
                grid-column-gap: 2em;
                @media (max-width: $w-s) {
                    display: flex;
                    flex-wrap: wrap;
                    // flex-direction: column;
                    font-size: var(--f-d1);
                }
                h2 {
                    margin-bottom: 0px;
                    font-weight: 400;
                }
                ul {
                    font-weight: 100;
                    padding-left: 4px;
                    list-style-type: none;
                    margin-top: 4px;
                    li {
                        + li {
                            padding-top: 4px;
                        }
                    }
                    @media (max-width: $w-s) {
                        font-weight: 300;
                    }
                }
            }
        }
    }
</style>

