---
import MainHead from '../components/MainHead.astro';
import Footer from '../components/Footer/index.jsx';
import Nav from '../components/Nav/index.jsx';
import DiaryLog from '../components/DiaryLog.astro';

const diaryLogModules = import.meta.glob('./diaryLog/**/*.md', { eager: true });

const diaryLogs = Object.entries(diaryLogModules)
  .map(([path, log]) => ({
    ...(log as { frontmatter: Record<string, unknown>; default: any }).frontmatter,
    url: path.replace(/^\.\//, '/').replace(/\.md$/, ''),
    Content: (log as { default: any }).default,
  }))
  .filter(({ publishDate }) => !!publishDate)
  .sort((a, b) => new Date(b.publishDate).valueOf() - new Date(a.publishDate).valueOf());
// const diaryLogs = Astro.fetchContent('./diaryLog/**/*.md');
---
<html lang="en">
  <head>
    <MainHead title="Diary Log | Divyaksh Shukla" />
    <style lang="scss">

      $w-s: 750px;
      .grid {
        display: grid;
        grid-template-columns: 50% 50%;
        grid-gap: 1rem;
        grid-auto-flow: row;
      }
      @media only screen and (max-width: $w-s) {
          .grid {
          display: grid;
          grid-template-columns: 100%;
          grid-gap: 1rem;
          grid-auto-flow: row;
        }
      }
    </style>
  </head>
  <body class="wrapper">
    <Nav />
    <div>
      <h1 class="title">Diary Log Entries</h1>
      <div class="grid">
        {diaryLogs.map((diaryLog) => (
          <DiaryLog log={diaryLog} />
        ))}
      </div>
    </div>
    <Footer />
  </body>
</html>
